# Entry point for zsh on macOS. Symlinked to ~/.zshrc by configure.sh.
# Sources the shared ~/.zshrc.common, then adds macOS-specific setup.

set -o vi

# Shared, platform-agnostic settings (env, history, common aliases).
[ -f ~/.zshrc.common ] && source ~/.zshrc.common

# enable homebrew on apple silicon
[[ -x /opt/homebrew/bin/brew ]] && eval "$(/opt/homebrew/bin/brew shellenv)"

# Only load interactive integrations in shells with a prompt.
if [[ $- = *i* ]]; then
  if [ -f /opt/homebrew/share/liquidprompt ]; then
    . ~/.liquidpromptrc
    . /opt/homebrew/share/liquidprompt
  fi
fi

